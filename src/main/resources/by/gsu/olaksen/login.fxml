<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="131.0" prefWidth="214.0" spacing="10" xmlns="http://javafx.com/javafx/25.0.1"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="by.gsu.olaksen.controller.LoginController">
    <Label text="Вход"/>
    <TextField fx:id="usernameField" prefHeight="26.0" prefWidth="150.0" promptText="Логин"/>
    <PasswordField fx:id="passwordField" prefHeight="26.0" prefWidth="170.0" promptText="Пароль"/>
    <Button onAction="#onLogin" text="Войти" defaultButton="true"/>
    <Label fx:id="errorLabel" textFill="red"/>
</VBox>