<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/25.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="by.gsu.olaksen.controller.RoomTabController">
    <GridPane AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10"
              hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="100"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="40" vgrow="NEVER"/>
            <RowConstraints minHeight="40" vgrow="NEVER"/>
            <RowConstraints vgrow="ALWAYS"/>
            <RowConstraints minHeight="40" vgrow="NEVER"/>
        </rowConstraints>

        <DatePicker fx:id="datePicker" GridPane.rowIndex="0" GridPane.columnIndex="0" prefWidth="160" maxWidth="160" minWidth="160"/>
        <TabPane fx:id="roomTabPane" tabClosingPolicy="UNAVAILABLE" GridPane.rowIndex="1" GridPane.columnIndex="0"
                 maxWidth="Infinity">
            <Tab text="Комната 1"/>
            <Tab text="Комната 2"/>
            <Tab text="Комната 3"/>
        </TabPane>
        <TableView fx:id="roomTable" GridPane.rowIndex="2" GridPane.columnIndex="0" maxWidth="Infinity" maxHeight="Infinity">
            <columns>
                <TableColumn fx:id="roomHourColumn" text="Час"/>
                <TableColumn fx:id="roomStatusColumn" text="Статус"/>
            </columns>
        </TableView>
        <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="0" maxWidth="Infinity">
            <Button text="Подтвердить бронь" onAction="#onConfirm"/>
            <Button text="Отменить бронь" onAction="#onCancel"/>
        </HBox>
    </GridPane>
</AnchorPane>