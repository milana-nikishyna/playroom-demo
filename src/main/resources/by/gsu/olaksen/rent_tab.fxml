<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/25.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="by.gsu.olaksen.controller.RentTabController">
    <TabPane tabClosingPolicy="UNAVAILABLE" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10"
             AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">
        <Tab text="Приставки" fx:id="consoleTab"/>
        <Tab text="Игры" fx:id="gameTab"/>
        <Tab text="Геймпады" fx:id="gamepadTab"/>
    </TabPane>
</AnchorPane>